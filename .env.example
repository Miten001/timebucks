# Telegram Bot Token from @BotFather
BOT_TOKEN=123456789:ABCdefGhIJKlmnOPQRsTUVwxyz

# Your Telegram user ID (admin) - get from @userinfobot
ADMIN_ID=123456789

# Sponsor channels - users MUST join these to play (this is your AD REVENUE)
# Format: comma-separated channel usernames WITHOUT @
# Example: SPONSOR_CHANNELS=mychannel1,mychannel2
# Leave empty to disable force-join
SPONSOR_CHANNELS=

# Coin to INR conversion (for redeem display)
# Example: 1000 coins = 10 INR means COIN_TO_INR=0.01
COIN_TO_INR=0.01

# Minimum coins required to redeem
MIN_REDEEM_COINS=5000
